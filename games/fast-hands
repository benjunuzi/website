                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>`;
                    mainText.innerText = "TAP NOW!";
                    mainText.classList.add('text-dark-950');
                    subText.innerText = "GO GO GO!";
                    subText.classList.add('text-dark-900');
                    playSound('beep');
                }, randomDelay);

            } else if (phase === 'waiting') {
                clearTimeout(state.classic.timerId);
                state.classic.phase = 'fail';
                playSound('buzzer');
                triggerBox.className = "relative w-full h-[380px] sm:h-[450px] rounded-3xl border border-red-500/30 bg-dark-900/90 flex flex-col items-center justify-center cursor-pointer select-none overflow-hidden transition-all duration-300 shadow-2xl";
                iconContainer.className = "mx-auto w-16 h-16 rounded-full bg-red-500/10 border border-red-500/20 flex items-center justify-center text-red-400 mb-2";
                iconContainer.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>`;
                mainText.innerText = "Too early!";
                subText.innerText = "You clicked before the panel turned green. Tap to restart.";
                progressBar.style.width = '0%';

            } else if (phase === 'ready') {
                const endTime = performance.now();
                const reactionTime = Math.round(endTime - state.classic.startTime);
                state.classic.phase = 'result';
                state.classic.lastScoreValue = reactionTime;
                
                playSound('chime');

                const currentRecord = loadScore('classic');
                if (!currentRecord || reactionTime < parseInt(currentRecord)) {
                    saveScore('classic', reactionTime);
                }

                state.classic.scores.push(reactionTime);
                if (state.classic.scores.length > 5) state.classic.scores.shift();
                
                const avg = Math.round(state.classic.scores.reduce((a, b) => a + b, 0) / state.classic.scores.length);
                document.getElementById('classic-recent-avg').innerHTML = `Recent Average (Last ${state.classic.scores.length}): <strong class="font-bold text-indigo-400 font-mono">${avg} ms</strong>`;

                triggerBox.className = "relative w-full h-[380px] sm:h-[450px] rounded-3xl border border-indigo-500/30 bg-dark-900/80 flex flex-col items-center justify-center cursor-pointer select-none overflow-hidden transition-all duration-300 shadow-2xl";
                iconContainer.className = "mx-auto w-16 h-16 rounded-full bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center text-indigo-400 mb-2";
                iconContainer.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>`;
                mainText.innerText = `${reactionTime} ms`;
                mainText.classList.remove('text-dark-950');
                subText.innerText = "Amazing speed! Tap outside the form to restart the test.";
                subText.classList.remove('text-dark-900');
                
                // Show submission panel
                classicSubmitArea.classList.remove('hidden');
                
                renderHighscores();

            } else if (phase === 'result' || phase === 'fail') {
                resetClassicGame();
            }
        }


        /* ================= AIM TRAINING SYSTEM ================= */
        const aimArena = document.getElementById('aim-arena');
        const aimTarget = document.getElementById('aim-target');
        const aimStartOverlay = document.getElementById('aim-start-overlay');
        const aimResultsOverlay = document.getElementById('aim-results-overlay');
        const aimCounter = document.getElementById('aim-counter');
        const aimSubmitArea = document.getElementById('aim-submit-area');

        function resetAimArena() {
            aimStartOverlay.classList.remove('hidden');
            aimResultsOverlay.classList.add('hidden');
            aimTarget.classList.add('hidden');
            state.aim.hits = 0;
            state.aim.individualTimes = [];
            aimCounter.innerText = `0 / ${state.aim.totalHitsNeeded}`;
            aimSubmitArea.classList.add('hidden');
        }

        function startAimGame() {
            initAudio();
            aimStartOverlay.classList.add('hidden');
            aimResultsOverlay.classList.add('hidden');
            state.aim.hits = 0;
            state.aim.individualTimes = [];
            state.aim.gameStartTime = performance.now();
            aimCounter.innerText = `0 / ${state.aim.totalHitsNeeded}`;
            spawnTarget();
        }

        function spawnTarget() {
            const arenaWidth = aimArena.clientWidth;
            const arenaHeight = aimArena.clientHeight;

            const padding = 50; 
            const randomX = Math.random() * (arenaWidth - padding * 2) + padding;
            const randomY = Math.random() * (arenaHeight - padding * 2) + padding;

            aimTarget.style.left = `${randomX}px`;
            aimTarget.style.top = `${randomY}px`;
            aimTarget.style.transform = 'translate(-50%, -50%) scale(0.6)';
            
            aimTarget.classList.remove('hidden');
            aimTarget.classList.add('flex');
            
            setTimeout(() => {
                aimTarget.style.transform = 'translate(-50%, -50%) scale(1)';
            }, 10);

            state.aim.targetStartTime = performance.now();
        }

        function handleTargetHit(e) {
            e.preventDefault();
            e.stopPropagation();

            const hitTime = performance.now();
            const reaction = hitTime - state.aim.targetStartTime;
            state.aim.individualTimes.push(reaction);

            state.aim.hits++;
            aimCounter.innerText = `${state.aim.hits} / ${state.aim.totalHitsNeeded}`;

            playSound('hit');

            if (state.aim.hits >= state.aim.totalHitsNeeded) {
                endAimGame();
            } else {
                spawnTarget();
            }
        }

        function endAimGame() {
            aimTarget.classList.add('hidden');
            const totalElapsed = (performance.now() - state.aim.gameStartTime) / 1000;
            const avgTime = Math.round(state.aim.individualTimes.reduce((a, b) => a + b, 0) / state.aim.individualTimes.length);
            state.aim.lastScoreValue = avgTime;

            const currentRecord = loadScore('aim');
            if (!currentRecord || avgTime < parseInt(currentRecord)) {
                saveScore('aim', avgTime);
            }

            document.getElementById('aim-results-avg').innerText = `${avgTime} ms`;
            document.getElementById('aim-results-time').innerText = `${totalElapsed.toFixed(2)}s`;
            
            aimResultsOverlay.classList.remove('hidden');
            aimSubmitArea.classList.remove('hidden');
            
            playSound('chime');
            renderHighscores();
        }

        window.onload = function() {
            renderHighscores();
        };
    </script>
</body>
</html>
