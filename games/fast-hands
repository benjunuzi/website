        function resetClassicGame() {
            clearTimeout(state.classic.timerId);
            state.classic.phase = 'idle';
            triggerBox.className = "relative w-full h-[380px] sm:h-[450px] rounded-3xl border border-dark-800 bg-dark-900/40 hover:bg-dark-900/60 flex flex-col items-center justify-center cursor-pointer select-none overflow-hidden transition-all duration-300 shadow-2xl";
