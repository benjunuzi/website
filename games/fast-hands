                    triggerBox.className = "relative w-full h-[380px] sm:h-[450px] rounded-3xl border border-emerald-500/30 bg-emerald-500 flex flex-col items-center justify-center cursor-pointer select-none overflow-hidden transition-all duration-75 shadow-[0_0_40px_rgba(16,185,129,0.3)]";
