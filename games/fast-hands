    <!-- Firebase SDK Imports -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInWithCustomToken, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, addDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Firebase Setup configuration & initialization
        let db = null;
        let auth = null;
        let useCloud = false;
        let currentUser = null;
        let appId = 'default-reaction-labs';

        if (typeof __app_id !== 'undefined' && __app_id) {
            appId = __app_id;
        }

        if (typeof __firebase_config !== 'undefined' && __firebase_config) {
            try {
                const firebaseConfig = JSON.parse(__firebase_config);
                const app = initializeApp(firebaseConfig);
                auth = getAuth(app);
                db = getFirestore(app);
                useCloud = true;
            } catch (e) {
                console.warn("Could not parse cloud config, standing by on Local Storage Mode:", e);
            }
        }

        // Expose critical cloud variables globally for simple page logic access
        window.db = db;
        window.auth = auth;
        window.useCloud = useCloud;
        window.appId = appId;
        window.currentUser = null;

        // Initialize Firestore with proper Rule 3 (Auth first, then queries)
        async function runInitialization() {
            if (useCloud) {
                const statusDot = document.getElementById('db-status-dot');
                const statusText = document.getElementById('db-status-text');

                statusText.innerText = "Connecting...";

                try {
                    // Rule 3: Always authenticate BEFORE starting any Firestore queries
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(auth, __initial_auth_token);
                    } else {
                        await signInAnonymously(auth);
                    }
                } catch (error) {
                    console.error("Cloud Authentication failed. Reverting to Local Storage standby.", error);
                    setupLocalFallback();
                    return;
                }

                onAuthStateChanged(auth, (user) => {
                    if (user) {
                        window.currentUser = user;
                        statusDot.className = "w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse";
                        statusText.innerText = "Cloud Sync Active";
                        setupCloudListeners();
                    } else {
                        setupLocalFallback();
                    }
                });
            } else {
                setupLocalFallback();
            }
        }

        // Set up Cloud Listeners (Rule 2: Fetch all, filter/sort in memory to avoid index errors)
        function setupCloudListeners() {
            const publicDataCollection = collection(db, 'artifacts', appId, 'public', 'data', 'scores');
            
            onSnapshot(publicDataCollection, (snapshot) => {
                const list = [];
                snapshot.forEach(doc => {
                    list.push(doc.data());
                });
                renderTables(list);
            }, (error) => {
                console.error("Cloud subscription read failed, using Local Backup:", error);
                setupLocalFallback();
            });
        }

        function setupLocalFallback() {
            const statusDot = document.getElementById('db-status-dot');
            const statusText = document.getElementById('db-status-text');
            statusDot.className = "w-2.5 h-2.5 rounded-full bg-amber-500";
            statusText.innerText = "Offline Standby Mode";

            // Local Highscore and Bot Highscore mock generator to keep the competitive experience fun
            const localScores = JSON.parse(localStorage.getItem('reaction_labs_leaderboard_local') || "[]");
            if (localScores.length === 0) {
                const mockData = [
                    { name: "ReflexBot_X", score: 142, mode: "classic" },
                    { name: "AlphaNerve", score: 168, mode: "classic" },
                    { name: "CyberGrip", score: 185, mode: "classic" },
                    { name: "NeuralPulse", score: 198, mode: "classic" },
                    { name: "PetaClick", score: 215, mode: "classic" },
                    { name: "ReflexBot_X", score: 180, mode: "aim" },
                    { name: "AlphaNerve", score: 210, mode: "aim" },
                    { name: "CyberGrip", score: 235, mode: "aim" },
                    { name: "NeuralPulse", score: 250, mode: "aim" },
                    { name: "PetaClick", score: 280, mode: "aim" },
                ];
                localStorage.setItem('reaction_labs_leaderboard_local', JSON.stringify(mockData));
                renderTables(mockData);
            } else {
                renderTables(localScores);
            }
        }

        // Unified rendering mechanism
        function renderTables(rawList) {
            // Filter and sort Classic (lower is better)
            const classicList = rawList
                .filter(item => item.mode === 'classic')
                .sort((a, b) => a.score - b.score)
                .slice(0, 10);

            // Filter and sort Aim (lower is better)
            const aimList = rawList
                .filter(item => item.mode === 'aim')
                .sort((a, b) => a.score - b.score)
                .slice(0, 10);

            populateTableRows('leaderboard-classic-rows', classicList);
            populateTableRows('leaderboard-aim-rows', aimList);
        }

        function populateTableRows(tbodyId, dataList) {
            const tbody = document.getElementById(tbodyId);
            tbody.innerHTML = '';

            if (dataList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="3" class="py-4 text-center text-xs text-dark-500">No telemetry recorded yet. Be the first to place!</td></tr>`;
                return;
            }

            dataList.forEach((entry, idx) => {
                const rank = idx + 1;
                let rankBadge = '';
                
                if (rank === 1) {
                    rankBadge = `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold font-mono">🥇</span>`;
                } else if (rank === 2) {
                    rankBadge = `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-slate-400/20 text-slate-300 text-xs font-bold font-mono">🥈</span>`;
                } else if (rank === 3) {
                    rankBadge = `<span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-700/20 text-amber-600 text-xs font-bold font-mono">🥉</span>`;
                } else {
                    rankBadge = `<span class="text-xs font-bold text-dark-500 font-mono pl-1.5">${rank}</span>`;
                }

                const safeName = entry.name.replace(/[^a-zA-Z0-9 ]/g, "").substring(0, 12);

                const tr = document.createElement('tr');
                tr.className = "border-b border-dark-800/40 hover:bg-dark-900/30 transition duration-150";
                tr.innerHTML = `
                    <td class="py-2.5 font-medium">${rankBadge}</td>
                    <td class="py-2.5 font-semibold text-dark-100">${safeName}</td>
                    <td class="py-2.5 text-right font-bold text-indigo-400 font-mono">${entry.score} ms</td>
                `;
                tbody.appendChild(tr);
            });
        }

        // Global registration of score posting handler
        window.postTelemetry = async function(mode, nickName, numericScore) {
            if (useCloud && window.currentUser) {
                try {
                    // Rule 1: strict paths: /artifacts/{appId}/public/data/{collectionName}
                    const publicDataCollection = collection(db, 'artifacts', appId, 'public', 'data', 'scores');
                    await addDoc(publicDataCollection, {
                        name: nickName,
                        score: Number(numericScore),
                        mode: mode,
                        userId: window.currentUser.uid,
                        timestamp: Date.now()
                    });
                    return true;
                } catch (err) {
                    console.error("Could not write document directly:", err);
                    return false;
                }
            } else {
                // Offline fallback storage writing
                const localScores = JSON.parse(localStorage.getItem('reaction_labs_leaderboard_local') || "[]");
                localScores.push({
                    name: nickName,
                    score: Number(numericScore),
                    mode: mode,
                    userId: "local-user",
                    timestamp: Date.now()
                });
                localStorage.setItem('reaction_labs_leaderboard_local', JSON.stringify(localScores));
                renderTables(localScores);
                return true;
            }
        };

        // Complete initialization
        runInitialization();
    </script>

    <!-- Audio & Reflex Mechanics Javascript logic -->
    <script>
        // High Quality synthesized browser sounds (Web Audio API)
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        let audioCtx = null;
        let audioEnabled = true;

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new AudioContext();
            }
        }

        function playSound(type) {
            if (!audioEnabled) return;
            initAudio();
            if (audioCtx.state === 'suspended') {
                audioCtx.resume();
            }

            const osc = audioCtx.createOscillator();
            const gainNode = audioCtx.createGain();
            osc.connect(gainNode);
            gainNode.connect(audioCtx.destination);

            const now = audioCtx.currentTime;

            if (type === 'beep') {
                // High-pitched success indicator
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(880, now); // A5 note
                gainNode.gain.setValueAtTime(0.08, now);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
                osc.start(now);
                osc.stop(now + 0.15);
            } else if (type === 'chime') {
                // Happy double chime on win
                osc.type = 'sine';
                osc.frequency.setValueAtTime(659.25, now); // E5
                osc.frequency.setValueAtTime(987.77, now + 0.08); // B5
                gainNode.gain.setValueAtTime(0.1, now);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.35);
                osc.start(now);
                osc.stop(now + 0.45);
            } else if (type === 'hit') {
                // Target hit impact sound
                osc.type = 'sine';
                osc.frequency.setValueAtTime(1200, now);
                osc.frequency.exponentialRampToValueAtTime(300, now + 0.08);
                gainNode.gain.setValueAtTime(0.12, now);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.08);
                osc.start(now);
                osc.stop(now + 0.08);
            } else if (type === 'buzzer') {
                // Low failed state buzzer
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(130, now);
                gainNode.gain.setValueAtTime(0.15, now);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.4);
                osc.start(now);
                osc.stop(now + 0.4);
            } else if (type === 'tick') {
                // Light subtle click
                osc.type = 'sine';
                osc.frequency.setValueAtTime(440, now);
                gainNode.gain.setValueAtTime(0.05, now);
                gainNode.gain.exponentialRampToValueAtTime(0.001, now + 0.03);
                osc.start(now);
                osc.stop(now + 0.03);
            }
        }

        function toggleAudio() {
            audioEnabled = !audioEnabled;
            const soundOnIcon = document.getElementById('sound-on-icon');
            const soundOffIcon = document.getElementById('sound-off-icon');
            if (audioEnabled) {
                soundOnIcon.classList.remove('hidden');
                soundOffIcon.classList.add('hidden');
            } else {
                soundOnIcon.classList.add('hidden');
                soundOffIcon.classList.remove('hidden');
            }
        }

        // Custom Safe Toast Messages
        function showToast(message, type = 'success') {
            const toastContainer = document.getElementById('toast-container');
            const toast = document.createElement('div');
            
            const bgClass = type === 'success' ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-400' : 'bg-indigo-500/10 border-indigo-500/30 text-indigo-400';
            
            toast.className = `flex items-center gap-2 border px-4 py-3 rounded-2xl shadow-lg backdrop-blur-md text-xs font-semibold select-none pointer-events-auto transform translate-y-2 opacity-0 transition-all duration-300 ${bgClass}`;
            toast.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>${message}</span>
            `;
            
            toastContainer.appendChild(toast);
            
            // Pop Animation
            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 10);
            
            // Auto Remove
            setTimeout(() => {
                toast.classList.add('translate-y-2', 'opacity-0');
                setTimeout(() => {
                    toast.remove();
                }, 300);
            }, 4000);
        }

        /* ================= GAME STATE VARIABLES ================= */
        const state = {
            classic: {
                phase: 'idle', // 'idle', 'waiting', 'ready', 'result', 'fail'
                startTime: 0,
                timerId: null,
                scores: [],
                lastScoreValue: 0
            },
            aim: {
                totalHitsNeeded: 15,
                hits: 0,
                targetStartTime: 0,
                individualTimes: [],
                gameStartTime: 0,
                lastScoreValue: 0
            }
        };


        /* ================= TAB MANAGEMENT ================= */
        function switchTab(tabId) {
            // Hide all tabs
            document.querySelectorAll('section[id^="tab-"]').forEach(sec => sec.classList.add('hidden'));
            // Display targeted tab
            document.getElementById(`tab-${tabId}`).classList.remove('hidden');

            // Reset game states when navigating back
            if (tabId === 'dashboard') {
                resetClassicGame();
                resetAimArena();
                renderHighscores();
            } else if (tabId === 'classic') {
                resetClassicGame();
            } else if (tabId === 'aim') {
                resetAimArena();
            }
        }


        /* ================= HIGH SCORE PERSISTENCE ================= */
        function saveScore(key, score) {
            localStorage.setItem(`reaction_labs_${key}`, score);
        }

        function loadScore(key) {
            return localStorage.getItem(`reaction_labs_${key}`);
        }

        function resetAllHighscores() {
            localStorage.removeItem('reaction_labs_classic');
            localStorage.removeItem('reaction_labs_aim');
            renderHighscores();
            playSound('buzzer');
            showToast("Cleared your local personal highscores!");
        }

        function renderHighscores() {
            // Load and render
            const classicVal = loadScore('classic');
            const aimVal = loadScore('aim');

            // Dashboard
            document.getElementById('stat-classic-best').innerText = classicVal ? `${classicVal} ms` : '-- ms';
            document.getElementById('stat-aim-best').innerText = aimVal ? `${aimVal} ms` : '-- ms';

            // Mini badges inside labs
            document.getElementById('classic-best-badge').innerText = classicVal ? `${classicVal} ms` : '-- ms';
            document.getElementById('aim-best-badge').innerText = aimVal ? `${aimVal} ms` : '-- ms';
        }


        /* ================= SUBMIT LEADERBOARD Telemetry ================= */
        async function submitScoreToLeaderboard(mode) {
            const inputId = `${mode}-nickname`;
            const areaId = `${mode}-submit-area`;
            const nameInput = document.getElementById(inputId);
            const submitArea = document.getElementById(areaId);

            const nickName = nameInput.value.replace(/[^a-zA-Z0-9 ]/g, "").trim();
            if (!nickName) {
                playSound('buzzer');
                showToast("Please enter a clean, valid nickname first!", "error");
                return;
            }

            const currentScore = mode === 'classic' ? state.classic.lastScoreValue : state.aim.lastScoreValue;
            if (currentScore <= 0) return;

            // Submit score to helper
            const status = await window.postTelemetry(mode, nickName, currentScore);
            
            if (status) {
                playSound('chime');
                showToast(`Your score of ${currentScore}ms has been uploaded!`);
                submitArea.classList.add('hidden');
                // Auto transition to Leaderboard
                setTimeout(() => {
                    switchTab('leaderboard');
                }, 800);
            } else {
                playSound('buzzer');
                showToast("An error occurred during submission.", "error");
            }
